# staging.env.example — server-side environment variables for {{APP_NAME}}
#
# Copy to staging.env on the VM (path set in .samohost.toml as envFile).
# NEVER commit staging.env — it contains secrets.
# This example file IS committed; it documents the shape, not the values.
#
# samohost reads the envFile path from .samohost.toml but never reads or
# writes its contents — it is sourced by the deploy script before build/start.

# Database
DATABASE_URL=postgresql://app_user:CHANGEME@127.0.0.1:5432/{{APP_DB_NAME}}
# APP_DATABASE_URL=postgresql://app_ro_user:CHANGEME@127.0.0.1:5432/{{APP_DB_NAME}}

# Application
NODE_ENV=production
PORT=3000

# Secrets (rotate after first deploy)
SESSION_SECRET=CHANGEME_min_32_chars

# Optional: GitHub token for reading private packages (if any)
# GITHUB_TOKEN=ghp_...
