# zero-routes single-reverse-proxy reference — back-compat form
# A legacy / single-service preview env with no routing rules: just one
# reverse_proxy handle. renderVhost({..., routes:[]}) must produce a
# Caddy-semantically-identical file (proven by caddy-adapt JSON equality).
samograph-zero.samo.cat {
	tls internal
	handle {
		reverse_proxy localhost:3000
	}
	log {
		output file /var/log/caddy/samograph-zero.log
		format json
	}
}
