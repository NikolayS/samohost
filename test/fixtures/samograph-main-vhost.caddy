# PROD vhost for samograph.samo.team — control-plane Caddy (91.99.233.145)
# reverse-proxies this host to VM:80 with Host preserved. Mirrors the
# samograph-main.caddy handle structure at the PROD ports.
#
# Provenance: captured read-only from samo@116.203.249.135 -p 2223
#   sha256sum /etc/caddy/sites.d/00-main-samograph.caddy
#   fce6b0f1be2103c9e8d09068c08f86831d30170993866531e174c2ebd4cfc4fe
# This file is the live-serving prod vhost for samograph.samo.team.
# caddy-a1 proves planFromApp(samographApp) is Caddy-semantically identical.
http://samograph.samo.team:80 {
	@stream path_regexp ^/calls/[^/]+/stream$
	@transcript path_regexp ^/calls/[^/]+/transcript
	handle @stream {
		reverse_proxy localhost:8888
	}
	handle /webhook* {
		reverse_proxy localhost:8189
	}
	handle @transcript {
		reverse_proxy localhost:8888
	}
	handle /__dev* {
		respond "not found" 404
	}
	handle {
		reverse_proxy localhost:3000
	}
	log {
		output file /var/log/caddy/samograph-prod.log
		format json
	}
}
